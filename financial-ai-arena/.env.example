# 复制为 .env 后填写。切勿把真实密钥提交到 Git。
# 在 skill 根目录复制本文件为 `.env` 后，取消注释并填入值（不要加引号）。
# 与 `configs/arena_config.yaml` 里各 provider 的 `env_api_key` 名称一致即可。
# ZHIPU_API_KEY=
# DEEPSEEK_API_KEY=
# MINIMAX_API_KEY=
# MIMO_API_KEY=
# MOONSHOT_API_KEY=   # yaml 中 kimi（Moonshot）等 openai_compat 使用

# 可选：模型覆盖（默认见 SKILL.md）
# ARENA_ZHIPU_MODEL=glm-4-plus
# ARENA_DEEPSEEK_MODEL=deepseek-chat
# ARENA_MINIMAX_MODEL=MiniMax-M2.7
# ARENA_MIMO_MODEL=mimo-v2.5-pro

# 可选：行情增强（与 jrj-quote / tushare 技能一致）
# JRJ_API_KEY=
# TUSHARE_TOKEN=

# 可选：人格生成脚本覆盖 writer 模型名
# ARENA_PERSONA_WRITER_MODEL=

# 可选：为「配置页写回 arena_config.yaml」接口加口令（POST 体 write_token 或请求头 X-Arena-Write-Token 须一致）；不设则仅本机回环可写
# ARENA_CONFIG_WRITE_TOKEN=

# 可选：擂台 sim 系统 prompt 中额外列出的文档路径（逗号分隔，仅文字提示，不会自动调 MCP）
# ARENA_EXTRA_SKILL_PATHS=D:\\work\\skills\\jrj-quote\\SKILL.md,D:\\work\\skills\\multi-search-engine\\SKILL.md

# 可选：每场 sim 结束后是否再调一轮各模型做「名次反馈」短文（1=开，0=关，省 API）
# ARENA_POST_GAME_FEEDBACK=1

# 可选：赛间把当前 NAV 快照写入 arena_live.json，供擂台页轮询刷新像素条（1=开，0=关）
# ARENA_LIVE_PROGRESS=1

# 可选：sim 开局用 Tushare 日线最近收盘初始化价格（需 TUSHARE_TOKEN；失败则回退漂移价）
# ARENA_USE_TUSHARE_PRICES=0

# 可选：每回合前用 DuckDuckGo Instant Answer 拉一句摘要塞进 user prompt（1=开；常为空，勿依赖）
# ARENA_DDG_SEARCH=0

# 可选：新一场 sim 是否把上一场 post_game_feedback 摘要拼进系统提示（1=开，0=关）
# ARENA_INJECT_PREV_FEEDBACK=1

# 可选：建议页对话写入 sim 系统提示时的最低质量分（0～1）
# ARENA_TRAINING_DIGEST_MIN_Q=0.42

# 可选：除内置并列 skill 外，再附加 skills/<子目录>/SKILL.md（逗号分隔子目录名）
# ARENA_EXTRA_SKILL_SUBDIRS=my-custom-skill,other-skill

# 可选：Moltpixel 公网画布（见 skills/moltpixel/SKILL.md 注册接口）
# MOLTPIXEL_API_KEY=

# 可选：烘焙擂台动图 poster-idle.gif（scripts/bake_reference_gif.py，无 Gemini 时用智谱视觉或其它 LLM 文本配色）
# ARENA_BAKE_ZHIPU_VISION_MODEL=glm-4v-flash
# ARENA_BAKE_ZHIPU_OPENAI_BASE=https://open.bigmodel.cn/api/paas/v4
